# Long-cache immutable assets — fonts and SVG logos are content-addressed by
# filename and only change when their bytes change. Browsers can keep them
# locally for a year and never revalidate.
/fonts/*
  Cache-Control: public, max-age=31536000, immutable

/logos/*
  Cache-Control: public, max-age=31536000, immutable

# Baseline security headers applied to every response. CSP allowlists Fathom
# (analytics) and self for everything else; tighten if scripts move inline.
/*
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  Content-Security-Policy: default-src 'self'; script-src 'self' https://cdn.usefathom.com; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self' https://cdn.usefathom.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self'
