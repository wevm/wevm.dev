{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "wevm-dev",
  "compatibility_date": "2025-09-24",
  "compatibility_flags": ["nodejs_compat"],
  "main": "./worker/index.ts",
  "observability": {
    "enabled": true,
  },
  "kv_namespaces": [
    {
      "binding": "KV",
      "id": "534dd0b501d04cecba0dea7f1ec0cd9d"
    },
  ],
  "triggers": {
    "crons": ["0 * * * *"],
  },
}
